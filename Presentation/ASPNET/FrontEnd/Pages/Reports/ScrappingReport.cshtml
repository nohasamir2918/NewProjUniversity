@page
@{
    ViewData["Title"] = "تقرير دفتر الشطب";
}
<style>
    a.btn.btn-danger {
        background: #fff;
        color: #f97316;
        border-bottom-left-radius: 15px;
        border: 1px solid;
        border-top-right-radius: 15px;
    }

    button.btn.btn-primary {
        background: #fff;
        color: blue;
        border-bottom-left-radius: 15px;
        border: 1px solid;
        border-top-right-radius: 15px;
        width:100%;
        padding: 10px 30px;
        box-shadow: 0 2px 15px rgb(22 42 249 / 35%);
    }

    .btn.btn-danger {
        padding: 10px 30px;
        box-shadow: 0 2px 15px rgb(249 115 22 / 35%);
    }
</style>
<h3 class="title">تقرير دفتر الشطب</h3>

<div id="scrappingReportApp" v-cloak class="bg-white rounded align-items-center justify-content-between p-4">
    <div class="row">
        <div class="col-md-3">
            <label>من تاريخ</label>
            <input type="date" v-model="filters.fromDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label>إلى تاريخ</label>
            <input type="date" v-model="filters.toDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label>المخزن</label>
            <select v-model="filters.warehouseId" class="form-control">
                <option value="">الكل</option>
                <option v-for="wh in warehouses" :key="wh.id" :value="wh.id">{{ wh.name }}</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>الصنف</label>
            <select v-model="filters.productId" class="form-control">
                <option value="">الكل</option>
                <option v-for="p in products" :key="p.id" :value="p.id">{{ p.name }}</option>
            </select>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-md-4"></div>
        <div class="col-md-2">
            <button class="btn btn-primary" v-on:click="loadReport">
                🔍
                بحث</button>
        </div>
        <div class="col-md-2">
            <a href="javascript:void(0)" class="pdf-btn btn btn-danger" v-on:click="openPdf">
                🖨️     طباعة
            </a>
           
        </div>
        <div class="col-md-4"></div>
    </div>
        
      <br />
      <br />
       
       
 

    <!-- جدول التقرير -->
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th> الحركة</th>
                <th>التاريخ</th>
                <th>المخزن</th>
                <th>الصنف</th>
                <th>الوحدة</th>
                <th>الكمية</th>
                <th>ملاحظات</th>
            </tr>
        </thead>
        <tbody>
            <tr v-for="item in pagedData" :key="item.moduleName + item.productCode">
                <td>
                    {{
                    item.moduleName === 'GoodsReceive' ? 'إذن إضافة' :
                    item.moduleName === 'IssueRequests' ? 'إذن صرف' :
                    item.moduleName === 'GoodsExamine'? 'إذن فحص' :
                    item.moduleName === 'PurchaseOrder' ? 'أمر توريد' :
                    ''
                    }}
                </td>

                <td>{{ formatDate(item.transactionDate) }}</td>
                <td>{{ item.warehouseName }}</td>
                <td>{{ item.productName }}</td>
                <td>{{ item.unitName }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.notes }}</td>
            </tr>
            <tr v-if="pagedData.length === 0">
                <td colspan="7" class="text-center">لا توجد بيانات</td>
            </tr>
        </tbody>
    </table>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-2">
        <div>الصفحة {{ currentPage }} من {{ totalPages }}</div>
        <div class="btn-group">
            
            <button class="btn btn-outline-primary" :disabled="currentPage===1" v-on:click="prevPage">السابق</button>
            <button class="btn btn-outline-primary" :disabled="currentPage===totalPages" v-on:click="nextPage">التالي</button>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        const { ref, computed, onMounted } = Vue;

        Vue.createApp({
            setup() {

                const filters = ref({
                    fromDate: '',
                    toDate: '',
                    warehouseId: '',
                    productId: ''
                });

                const report = ref([]);
                
              

                const pageSize = ref(5);
                const currentPage = ref(1);

                const totalPages = computed(() => Math.ceil(report.value.length / pageSize.value) || 1);
                const pagedData = computed(() => {
                    const start = (currentPage.value - 1) * pageSize.value;
                    return report.value.slice(start, start + pageSize.value);
                });

                const loadReport = async () => {
                    try {
                        const response = await axios.get('/api/Scrapping/scrapping', {
                            params: {
                                fromDate: filters.value.fromDate,
                                toDate: filters.value.toDate,
                                warehouseId: filters.value.warehouseId,
                                productId: filters.value.productId
                            }
                        });

                        const list =
                            response.data?.data?.content?.data ??
                            response.data?.data?.data ??
                            response.data?.data ??
                            [];

                        report.value = Array.isArray(list) ? list : [];
                        currentPage.value = 1;
                    } catch (e) {
                        console.error(e);
                        report.value = [];
                    }
                };

                const warehouses = Vue.ref([]);

                const loadWarehouses = async () => {
                    try {
                        const res = await axios.get('/api/Warehouse/GetWarehouseList');
                        console.log('RAW RESPONSE:', res.data);

                        // فك التغليف للوصول للقائمة الفعلية
                        warehouses.value = res.data?.content?.data ?? [];

                        
                    } catch (e) {
                        console.error('Error loading warehouses:', e);
                    }
                };

                const products = ref([]);
                const loadProducts = async () => {
                    try {
                        const res = await axios.get('/api/Product/GetProductList');
                       // products.value = res.data?.data?.content?.data ?? res.data?.data ?? [];
                        products.value = res.data?.content?.data ?? [];
                        //products.value = res.data?.data ?? [];
                    } catch (e) {
                        console.error('Error loading products', e);
                    }
                };

                const formatDate = (date) => date ? new Date(date).toLocaleDateString() : '';

                const nextPage = () => { if (currentPage.value < totalPages.value) currentPage.value++; };
                const prevPage = () => { if (currentPage.value > 1) currentPage.value--; };

                // Generate server-side page URL to avoid hard-coded path issues
                const pdfUrlBase = '@Url.Page("/Reports/ScrappingReportPdf")';

                const openPdf = () => {
                    // Build URL with current filters (encode for safety)
                    const params = new URLSearchParams();
                    if (filters.value.fromDate) params.append('fromDate', filters.value.fromDate);
                    if (filters.value.toDate) params.append('toDate', filters.value.toDate);
                    if (filters.value.warehouseId) params.append('warehouseId', filters.value.warehouseId);
                    if (filters.value.productId) params.append('productId', filters.value.productId);

                    const url = pdfUrlBase + (params.toString() ? ('?' + params.toString()) : '');
                    window.open(url, '_blank');
                };

                onMounted(() => {
                    loadWarehouses();   
                    loadProducts();
                });

                return {
                    filters, report, warehouses, products,
                    pagedData, currentPage, totalPages,
                    formatDate, nextPage, prevPage, loadReport, openPdf
                };
            }
        }).mount('#scrappingReportApp');
    </script>
}
