@page
@{
    ViewData["Title"] = "محضر جرد الأصناف";
}
<h3 class="title"> محضر جرد الأصناف </h3>
<style>
    body {
        direction: rtl;
        font-family: "Times New Roman", serif;
        background: #f5fI5F5;
    }

    #content, #content * {
        direction: rtl !important;
        text-align: right;
        font-size: 19px;
    }

    .print-area {
        width: 210mm;
        min-height: 297mm;
        background: #fff;
        padding: 10mm;
        margin: auto;
        border: 1px solid #000;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    td, th {
        border: 1px solid #000;
        padding: 6px;
        vertical-align: middle;
    }

    .no-border td {
        border: none;
    }

    .center {
        text-align: center !important;
    }

    .bold {
        font-weight: bold;
    }

    .title {
        font-size: 20px;
        text-decoration: underline;
        margin: 5px 0;
    }

    .section {
        margin-top: 10px;
        font-size: 14px;
        line-height: 1.9;
    }



    @@media print {
        .no-print {
            display: none;
        }
    }
</style>
<div id="app">
    <div id="content" class="print-area form-sheet">
       
        <div class="row">
            <div class="col-md-6">
                <span style="color:#000;font-weight:bold;">اسم الجهة: {{ state.company.name }}</span>
                <br />
                <span style="color:#000;font-weight:bold;">
                    مخزن: {{ state.warehouseName || '—' }}
                </span>

                <br />
                <span style="color:#000;font-weight:bold;">تاريخ الجرد: {{ state.date }}</span>
            </div>
            <div class="col-md-6">
                <span style="color:#000;font-weight:bold;">نموذج 6 مخازن حكومة"</span>
                <br />
                <br />
                <span style="color:#000;font-weight:bold;">اسم صاحب العهدة:</span>
                
            </div>


        </div>
        <br />
        <!-- ===== بيانات ===== -->



        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:4%">رقم الصنف</th>
                    <th style="width:20%">اسم الصنف</th>
                    <th style="width:8%">الوحدة</th>
                    <th style="width:8%">الموجود في واقع الجرد</th>
                    <th style="width:10%">حالة الصنف</th>
                    <th style="width:10%">الرصيد الدفتري</th>
                    <th style="width:10%">حالة الصنف</th>
                    <th style="width:10%">الزيادة </th>
                    <th style="width:10%">العجز</th>
                    <th style="width:10%">سعر الوحدة</th>
                    <th style="width:10%">القيمة</th>
                </tr>
            </thead>
            <tbody>
                <tr v-for="(item, index) in state.mappedItems" :key="index">
                    <td class="center">{{ index + 1 }}</td>
                    <td>{{ item.product }}</td>
                    <td class="center">{{ item.unit }}</td>
                    <td class="center">{{ item.movement }}</td>
                    <td class="center">{{ item.unitPrice }}</td>
                    <td class="center">{{ item.value }}</td>
                    <td class="center">{{ item.status }}</td>
                </tr>

                <!-- صفوف فاضية للطباعة اليدوية -->
                <tr v-for="i in 4" :key="'empty-' + i">
                    <td>&nbsp;</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>

                </tr>
            </tbody>
        </table>
    </div>

</div>



@section scripts {
    <script src="~/FrontEnd/Pages/GoodsReceives/GoodsReceivePdf.cshtml.js"></script>
}
