    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef"></div> <!-- سيملأه Grid باللغة العربية -->
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/InventoryStocktaking/InventoryStocktaking.cshtml.js"></script>
}
