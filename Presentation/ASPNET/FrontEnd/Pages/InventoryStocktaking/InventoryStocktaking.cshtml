@page
@{
    ViewData["Title"] = "تقرير جرد المخزن";
}
<h3 class="title"> تقرير جرد المخزن</h3>
<div id="app" v-cloak>
    <div class="row">
        <div class="col-md-4">
            <label>المخزن</label>
            <div ref="warehouseRef"></div>
            <label class="text-danger">{{ state.errors.warehouseId }}</label>
