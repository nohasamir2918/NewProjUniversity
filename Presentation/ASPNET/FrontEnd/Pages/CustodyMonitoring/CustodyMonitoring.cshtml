@page
@{
    ViewData["Title"] = "تقرير مراقبة العهدة";
}
<h3 class="title">تقرير مراقبة العهدة</h3>
<div id="app" v-cloak>
    <div class="row">
        <div class="col-md-4">
            <label>الإدارة</label>
            <div ref="departmentRef"></div>
            <label class="text-danger">{{ state.errors.departmentId }}</label>
        </div>

        <div class="col-md-4">
            <label>الموظف</label>
            <div ref="employeeRef"></div>
            <label class="text-danger">{{ state.errors.employeeId }}</label>
        </div>

        <div class="col-md-4">
            <label>الصنف</label>
            <div ref="productRef"></div>
            <label class="text-danger">{{ state.errors.productId }}</label>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef"></div> <!-- سيملأه Grid باللغة العربية -->
            </div>
        </div>
    </div>

    <div id="print-section" style="display:none">
        <div id="content" class="print-area form-sheet">
            <h3 class="title text-center"> محضر جرد الأصناف </h3>
            <div class="print-header">
                <div class="right">
                    <span class="bold">اسم الجهة: جامعة الزقازيق</span><br>
                    <span class="bold">مخزن: {{ state.warehouseName || '—' }}</span><br>
                    <span class="bold">تاريخ الجرد:</span>
                </div>

                <div class="left">
                    <span style="font-weight:normal; font-size:12px;">نموذج 6 مخازن حكومة</span><br><br>
                    <span class="bold">اسم صاحب العهدة:</span>
                </div>
            </div>

            <br />
            <!-- ===== بيانات ===== -->

            <table class="items-table">
                <colgroup>
                    <col style="width:10%">
                    <col style="width:10%">
                    <col style="width:8%">
                    <col style="width:8%">
                    <col style="width:10%">
                    <col style="width:10%">
                    <col style="width:10%">
                    <col style="width:8%">
                    <col style="width:8%">
                    <col style="width:10%">
                    <col style="width:10%">
                </colgroup>
                <thead>
                    <tr>
                        <th>رقم الصنف</th>
                        <th>اسم الصنف</th>
                        <th>الوحدة</th>
                        <th>الموجود في واقع الجرد</th>
                        <th>حالة الصنف</th>
                        <th>الرصيد الدفتري</th>
                        <th>حالة الصنف</th>
                        <th>الزيادة </th>
                        <th>العجز</th>
                        <th>سعر الوحدة</th>
                        <th>القيمة</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="(item, index) in mappedItems" :key="index">
                        <td class="center">{{ index + 1 }}</td>
                        <td>{{ item.name }}</td>
                        <td class="center">{{ item.unitMeasureName }}</td>
                        <td class="center"></td>
                        <td class="center"></td>
                        <td class="center">{{ item.quantity }}</td>
                        <td class="center"></td>
                        <td class="center"></td>
                        <td class="center"></td>
                        <td class="center">{{ item.unitPrice }}</td>
                        <td class="center">{{ item.total }}</td>

                    </tr>

                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/CustodyMonitoring/CustodyMonitoring.cshtml.js?id=2"></script>
}
