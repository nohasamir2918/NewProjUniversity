@page
@{
    ViewData["Title"] = "قائمة استلام البضائع";
}
<h3 class="title"> استلام البضائع</h3>
<div id="app" v-cloak>
    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" ref="mainModalRef" id="MainModal" aria-hidden="true" tabindex="-1" data-bs-focus="false" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ state.mainTitle }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" v-model="state.id" id="Id" name="Id" />
                    <form>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>المعلومات الأساسية</h5>
                                    </div>

                                    <div class="card-body">
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="ReceiveDate">تاريخ طلب الاضافة</label>
                                                <input ref="receiveDateRef">
                                                <label class="text-danger">{{ state.errors.receiveDate }}</label>
                                            </div>

                                            <div class="col-md-6">
                                                <label for="Number">الرقم</label>
                                                <input ref="numberRef" v-model="state.number" readonly>
                                            </div>
                                        </div>

                                        <div class="row mb-2">
                                            <div class="col-md-4">
                                                <label>أمر التوريد</label>
                                                <div ref="purchaseOrderIdRef"></div>
                                            </div>

                                            <div class="col-md-4">
                                                <label>الحالة</label>
                                                <div ref="statusRef"></div>
                                            </div>

                                            <div class="col-md-4">
                                                <label>المخزن</label>
                                                <div ref="warehouseRef"></div>
                                                <label class="text-danger">{{ state.errors.warehouseId }}</label>
                                            </div>
                                        </div>
                                      

                                        <div class="row mb-2">
                                            <div class="col-md-12">
                                                <label for="Description">الوصف</label>
                                                <textarea class="form-control" rows="3" v-model="state.description"></textarea>
                                                <label class="text-danger">{{ state.errors.description }}</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <div id="ComplexDiv" :style="{ display: state.showComplexDiv ? 'block' : 'none' }">
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>تفاصيل المنتجات المستلمة</h5>
                                    </div>

                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="grid-container">
                                                    <div ref="secondaryGridRef"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="card shadow-sm">
                                    <div class="card-header text-white">
                                        <h5 class="mb-0">الملخص</h5>
                                    </div>

                                    <div class="card-body">
                                        <div class="row justify-content-end">
                                            <div class="col-md-6">
                                                <div class="d-flex justify-content-between py-2">
                                                    <span class="fw-bold">إجمالي الحركة</span>
                                                    <span id="TotalMovement" class="fw-bold text-success">{{ state.totalMovementFormatted }}</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>

                    <button type="button"
                            id="MainSaveButton"
                            class="btn"
                            v-bind:class="state.deleteMode ? 'btn-danger' : 'btn-primary'"
                            v-on:click="handler.handleSubmit"
                            v-bind:disabled="state.isSubmitting">

                        <span class="spinner-border spinner-border-sm me-2" v-if="state.isSubmitting" role="status" aria-hidden="true"></span>

                        <span v-if="!state.isSubmitting">{{ state.deleteMode ? 'حذف' : 'حفظ' }}</span>
                        <span v-else>{{ state.deleteMode ? 'جاري الحذف...' : 'جاري الحفظ...' }}</span>

                    </button>
                </div>

            </div>
        </div>
    </div>

</div>

@section scripts {
    <script src="~/FrontEnd/Pages/GoodsReceives/GoodsReceiveList.cshtml.js"></script>
}
