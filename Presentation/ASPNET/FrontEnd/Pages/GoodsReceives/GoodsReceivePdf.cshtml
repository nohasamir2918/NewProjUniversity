@page
@{
    ViewData["Title"] = "اذن اضافة  البضائع PDF";
}
<h3 class="title"> اذن اضافة  البضائع PDF</h3>
<style>
    body {
        direction: rtl;
        font-family: "Times New Roman", serif;
        background: #f5fI5F5;
    }

    #content, #content * {
        direction: rtl !important;
        text-align: right;
        font-size: 19px;
    }

    .print-area {
        width: 210mm;
        min-height: 297mm;
        background: #fff;
        padding: 10mm;
        margin: auto;
        border: 1px solid #000;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    td, th {
        border: 1px solid #000;
        padding: 6px;
        vertical-align: middle;
    }

    .no-border td {
        border: none;
    }

    .center {
        text-align: center !important;
    }

    .bold {
        font-weight: bold;
    }

    .title {
        font-size: 20px;
        text-decoration: underline;
        margin: 5px 0;
    }

    .section {
        margin-top: 10px;
        font-size: 14px;
        line-height: 1.9;
    }



    @@media print {
        .no-print {
            display: none;
        }
    }
</style>
<div id="app">
    <div id="content" class="print-area form-sheet">
        <!-- ===== رأس الصفحة ===== -->
       @*  <table class="header-table">
            <tr>
                <td class="right">
                    <strong>اسم الجهة:</strong><br>
                    {{ state.company.name }}
                </td>

                <td class="center title-cell">
                    <div class="form-title">إذن إضافة مخزنية</div>
                </td>

                <td class="left">
                    <strong>التاريخ:</strong> {{ state.date }}<br>
                    <strong>رقم الإذن:</strong> {{ state.number }}
                </td>
            </tr>
        </table> *@
        <div class="row">
            <div class="col-md-6">
                <span style="color:#000;font-weight:bold;">اسم الجهة: {{ state.company.name }}</span>
                <br />
                <span style="color:#000;font-weight:bold;">مخزن: ..............</span>
                <br />
                <span style="color:#000;font-weight:bold;">التاريخ: {{ state.date }}</span>
            </div>
            <div class="col-md-6"> <span style="color:#000;font-weight:bold;">اذن اضافة</span>
                <br />
                <span style="color:#000;font-weight:bold;">وارد من: {{ state.vendor.name }}</span>
                <br />
                <span style="color:#000;font-weight:bold;">سند الاضافة: ...........</span>
                <span style="color:#000;font-weight:bold;">بتاريخ: ...........</span>
                </div>
            

        </div>
        <br />
        <!-- ===== بيانات ===== -->
       

      
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:4%">رقم الصنف</th>
                    <th style="width:20%">اسم الصنف</th>
                    <th style="width:8%">الوحدة</th>
                    <th style="width:8%">الكمية</th>
                    <th style="width:10%">سعر الوحدة</th>
                    <th style="width:10%">القيمة</th>
                    <th style="width:10%">حالة الصنف</th>
                    <th style="width:15%">الملاحظات</th>
                   
                </tr>
            </thead>
            <tbody>
                <tr v-for="(item, index) in state.mappedItems" :key="index">
                    <td class="center">{{ index + 1 }}</td>
                    <td>{{ item.product }}</td>
                    <td class="center">{{ item.unit }}</td>
                    <td class="center">{{ item.movement }}</td>
                    <td class="center">{{ item.unitPrice }}</td>
                    <td class="center">{{ item.value }}</td>
                    <td class="center">{{ item.status }}</td>
                    <td>{{ item.notes }}</td>
                    @* <td class="center">{{ item.amount }}</td> *@
                </tr>

                <!-- صفوف فاضية للطباعة اليدوية -->
                <tr v-for="i in 4" :key="'empty-' + i">
                    <td>&nbsp;</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                 
                </tr>
            </tbody>
        </table>
        <br />
        <div class="row">
            <div class="col-md-6">
                <div class="tafqeet" style="text-align:right">
                    <strong>فقط مبلغ :</strong>
                    {{ state.amountInWords }}
                </div>
            </div>
            <div class="col-md-3">
                <div class="tafqeet" style="text-align:right">
                    <strong>الاجمالي :</strong>
                    ...............
                </div>
            </div>
            <div class="col-md-3">
                <div class="tafqeet" style="text-align:right">
                    <strong> كاتب الشطب :</strong>
                    ..............
                </div>
            </div>
        </div>
        
        <br />


      <div class="row">
          <div class="col-md-9">
                <span style="color:#000;font-weight:bold;">    .استلمت الأصناف المبينة أعلاه بحالة جيدة وتم اضافتها في دفتر عهدة المخزن</span>
          </div>
          <div class="col-md-3">
                <span style="color:#000;font-weight:bold;">أمين المخزن/....... </span>
            </div>
      </div>
      <br />
        <div class="row">
            <div class="col-md-9">
                <span style="color:#000;font-weight:bold;">  
                    *فاتورة - اذن ارتجاع - اذن صرف - كشف الزيادة - شهادة إدارية
                    <br />
                **(1) جديد (2) مستعمل (3) قابل للإصلاح (4) كهنة وخردة
                </span>
           
        </div>
    

    </div>
    <div class="row">
        <div class="col-md-6"></div>
            <div class="col-md-3">
                <span style="color:#000;font-weight:bold;">يعتمد</span>
            </div>
            <div class="col-md-3">
                <span style="color:#000;font-weight:bold;">مدير المخزن </span>
            </div>
    </div>
</div>

</div>



@section scripts {
    <script src="~/FrontEnd/Pages/GoodsReceives/GoodsReceivePdf.cshtml.js"></script>
}
