@page
@{
    ViewData["Title"] = "فحص البضائع PDF";
}
<div class="row">
    <div class="col-md-6"><h3 style="font-size: 1.75rem !important;text-decoration:none !important;text-align:right !important;margin-bottom:20px !important;"> فحص البضائع  </h3></div>
    <div class="col-md-6">
        <div class="no-print text-center mb-3">
            <!-- زر خارج الطباعة -->
            <button class="btn btn-danger" id="PrintResultButton" onclick='printar("certificat")'>
                <span class="print-icon">🖨️</span>
                <span class="print-text">طباعة</span>
            </button>
        </div>
    </div>
</div>

<style>
    body {
        direction: rtl;
        font-family: "Times New Roman", serif;
        background: #f5fI5F5;
    }

    #border, #border * {
        direction: rtl !important;
        text-align: right;
        font-size: 16px;
    }

    .print-area {
        width: 210mm;
        min-height: 297mm;
        background: #fff;
        padding: 10mm;
        margin: auto;
        border: 1px solid #000;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    td, th {
        border: 1px solid #000;
        padding: 6px;
        vertical-align: middle;
    }

    .no-border td {
        border: none;
    }

    .center {
        text-align: center !important;
    }

    .bold {
        font-weight: bold;
    }

    .title {
        font-size: 20px;
        text-decoration: underline;
        margin: 5px 0;
    }

    .section {
        margin-top: 10px;
        font-size: 14px;
        line-height: 1.9;
    }

   

    @@media print {
        .no-print {
            display: none;
        }
    }
</style>

<div id="certificat">
   
        <div id="border" style="height:29.7cm;padding-top:.6cm;font-size:12px;width:21cm;background:white;margin:1cm;font-family: 'Arial regular'!important;font-size:10pt;padding:10px;">



            <div id="content" style="padding: 3px;">
            <div class="row">
                <div class="col-md-6">
                    <span style="color:#000;font-weight:bold;">
                        اسم الجهة: كلية الزراعة - جامعة الزقازيق
                </span></div>
                <div class="col-md-6 center">
                    <span style="color:#000;font-weight:bold;">
                        نموذج رقم (12)
                    </span>
                </div>
            </div>
            <br />
            <div class="row">
                <div class="col-md-12 ">
                    <h2 style="text-align:center;font-size:30px;text-decoration:underline;">محضر لجنة الفحص</h2>
                </div>
            </div>
          <br />
            <div class="row">
                <div class="col-md-12">
            <p style="text-align:right"  class="text">
                اليوم {{ state.examineDayName }}
                الموافق {{ state.examineDate }}
                
               
                اجتمعت لجنة الفحص المشكلة بالقرار رقم
                (<strong>{{ state.committeeDesionNumber }}</strong>)
                الصادر بتاريخ <strong>{{ state.commiteeDate }} </strong>

                <strong style="margin-right:3px;">برئاسة السيد / {{ chairman.employeePositionName }}  </strong>
                {{ chairman.employeeName }}

            </p>
            <br />
            <p style="text-align:right"><strong>وعضوية كل من:</strong></p>
            <br />
            <div class="committee">
                <p v-for="(member,index) in members" :key="index">
                    <strong>السيد /</strong> {{ member.employeeName }} —
                    <strong>الوظيفة /</strong> {{ member.employeePositionName }}
                </p>
            </div>


            <p class="paragraph">
                وقد قامت اللجنة بفحص الأصناف المدرجة طبقًا
                لأمر التوريد الصادر إلى
                <strong>{{ state.vendorName }}</strong>
                برقم
                <strong>{{ state.purchaseOrderNumber }}</strong>
                بتاريخ
                <strong>{{ state.purchaseOrderDate }}</strong>
                وبالمواصفات المنصوص عليها بكراسة الشروط
                والمواصفات والعقد المبرم مع المورد
                وبحضور / عدم حضور المورد أو مندوبه.
            </p>
                </div>
            </div>
            <br />
            <div class="row">
                <div class="col-md-12">
          
            <table class="inspection-table">
                <thead>
                    <tr>
                        <th>اسم الصنف ومواصفاته</th>
                        <th>عدد أو مقدار</th>
                        <th>الوحدة</th>
                        <th>نسبة المئوية لمقادير الفحص</th>
                        <th>مقبول</th>
                        <th>مرفوض</th>
                        <th>اسباب القبول والرفض</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="(item,index) in state.mappedItems" :key="index">
                        <td>
                            <strong>{{ item.product }}</strong>
                            <br />
                            <span>{{ item.description }}</span>
                        </td>

                        <td>{{ item.qty }}</td>
                        <td>{{ item.unit }}</td>
                        <td>{{ item.matchPercent }}</td>
                        <td class="check">{{ item.accepted ? '✔' : '' }}</td>
                        <td class="check">{{ item.rejected ? '✔' : '' }}</td>
                        <td>{{ item.reason }}</td>
                    </tr>
                </tbody>
            </table>
            </div>
            </div>
            <br />
            <div class="row">
                <div class="col-md-4 center">
                    <span style="color:#000;font-weight:bold;">لجنة الفحص</span>
                </div>
                <div class="col-md-4 center">
                    <span style="color:#000;font-weight:bold;">رئيس لجنة الفحص</span>

                    <span style="color:#000;font-weight:bold;"> الاسم:...............</span>
                    <span style="color:#000;font-weight:bold;"> التوقيع:.................</span>
                </div>
                <div class="col-md-4 center">
                    <span style="color:#000;font-weight:bold;">  اعتماد السلطة المختصة</span>
                    <span style="color:#000;font-weight:bold;"> الاسم:...............</span>
                    <span style="color:#000;font-weight:bold;"> التوقيع:.................</span>
                </div>
            </div>
        </div>
       
      

</div>


    
        </div>

<script>

        function printar(k) {


        var restorepage2 = document.body.innerHTML;
        var printcontent2 = $('#' + k).html();

        document.body.innerHTML = printcontent2;

                    var css = `@@page{margin: 0cm 0cm 0cm 0cm!important;}#border{font-size:16px;}.col-md-4 {width: 33.33333333%;}.col-md-8 {width: 66.66666667%;}.col-md-6 {width: 50%;}.col-md-7 {width: 58.33333333%;}.col-md-5 {width: 41.66666667% !important;}.col-md-2{width: 16.66666667% !important;}  table,td,th{border:1px solid #d3c8bc;} table{width:100%;}  .col-md-1 {flex: 0 0 8.33333%;max-width: 8.33333%;} .col-md-3 {flex: 0 0 auto;width: 25%;} .col-md-12{width:100%;}.col-md-6 {-webkit-flex: 0 0 50%;-ms-flex: 0 0 50%;flex: 0 0 50%; max-width: 50%; }`,
            head = document.head || document.getElementsByTagName('head')[0],
        style = document.createElement('style');
        style.type = 'text/css';
        style.media = 'print';
        if (style.styleSheet) {
            style.styleSheet.cssText = css;
        }
        else {
            style.appendChild(document.createTextNode(css));
        }
        head.appendChild(style);
        window.print();
        history.go(0);
        window.location.reload();
        document.body.innerHTML = restorepage2;




    }
</script>
@section scripts {
    <script src="~/FrontEnd/Pages/GoodsExamine/GoodsExaminePdf.cshtml.js"></script>
}
