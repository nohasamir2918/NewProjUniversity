@page
@{
    ViewData["Title"] = "تسجيل خروج";
}
<style>
    a{
        display:none;
    }
    /* Center the card and give the page a gradient background */
    #app {
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Card styling */
    .login-card-body {
        background: #ffffffee; /* semi-transparent white */
        padding: 2.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        text-align: center;
        max-width: 400px;
        width: 100%;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .login-card-body:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 45px rgba(0,0,0,0.3);
        }

    /* Title message */
    .login-box-msg {
        font-size: 1.6rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 1.5rem;
        position: relative;
    }

        /* Decorative underline under title */
        .login-box-msg::after {
            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background: #2575fc;
            margin: 8px auto 0;
            border-radius: 2px;
        }

    /* Info text */
    .form-group p {
        font-size: 1rem;
        color: #555;
        margin: 0.3rem 0;
    }

    /* Button styling */
    .btn-primary {
        position: relative;
        background: linear-gradient(45deg, #6a11cb, #2575fc);
        border: none;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 50px;
        padding: 0.75rem 1.5rem;
        transition: 0.3s ease;
        overflow: hidden;
    }

        .btn-primary:hover {
            background: linear-gradient(45deg, #2575fc, #6a11cb);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

    /* Spinner animation */
    .spinner-border {
        border-width: 0.15em;
        border-top-color: #ffffff;
        animation: spin 0.8s linear infinite;
        margin-right: 0.5rem;
    }

   @@keyframes spin {
        0%

    {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }

    }

    /* Disable button state */
    .btn[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
        background: #999 !important;
    }

    /* Optional: subtle floating effect on the card */
    @@keyframes floatCard {
        0%, 100%

    {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-5px);
    }

    }

    .login-card-body {
        animation: floatCard 6s ease-in-out infinite;
    }

    .card {
        background-color:transparent;
    }
</style>
<div class="container-fluid" id="app" v-cloak>

    <div class="card-body login-card-body">
        <p class="login-box-msg">@ViewData["Title"]</p>



        <div class="social-auth-links text-center mb-3">
            <div class="row">
                <div class="col-md-12">
                    <form v-on:submit.prevent="handleSubmit">
                        <div class="form-group mb-2 text-center">
                            <p>هل انت متأكد من تسجيل الخروج?</p>
                            <p>اضغط لاسفل لكي يتم تسجيل الخروج كاملا.</p>
                        </div>
                        <button type="submit"
                                v-bind:disabled="state.isSubmitting"
                                class="btn btn-primary w-100 mb-2">
                            <span class="spinner-border spinner-border-sm me-2"
                                  v-if="state.isSubmitting"
                                  role="status"
                                  aria-hidden="true"></span>
                            <span>{{ state.isSubmitting ? '...' : 'تسجيل خروج' }}</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>

</div>


@section scripts {
    <script src="~/FrontEnd/Pages/Accounts/Logout.cshtml.js"></script>
}
